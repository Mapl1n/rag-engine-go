# RAG 引擎配置
SERVER_PORT=8081

# ElasticSearch
ES_HOST=localhost
ES_PORT=9200
ES_INDEX=documents

# Apache Tika
TIKA_URL=http://localhost:9998

# Ollama Embedding
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3

# LLM (可选，不配置则仅检索模式)
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
